APP_NAME="Sistem Tracer Study UNISYA"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tracer.unisya.ac.id
APP_LOCALE=id
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sitras_unisya
DB_USERNAME=sitras_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.unisya.ac.id

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tracerstudy@unisya.ac.id
MAIL_FROM_NAME="Tracer Study UNISYA"

# WhatsApp Gateway UNISYA
WHATSAPP_GATEWAY_URL=https://wacenter.unisya.ac.id/send-message
WHATSAPP_API_KEY=
WHATSAPP_SENDER=

# Sanctum & CORS
SANCTUM_STATEFUL_DOMAINS=tracer.unisya.ac.id
FRONTEND_URL=https://tracer.unisya.ac.id

# Konfigurasi OTP (07_SECURITY.md)
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Konfigurasi Login Lockout (07_SECURITY.md)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Konfigurasi Employer Token
EMPLOYER_TOKEN_EXPIRY_DAYS=30

# Konfigurasi File Upload
MAX_UPLOAD_SIZE_KB=10240

# Telescope (disable di production)
TELESCOPE_ENABLED=false

# AWS (opsional, untuk future S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (opsional)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
